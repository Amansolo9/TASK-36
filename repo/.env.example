# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# All variables below are REQUIRED unless marked optional.

# Database (REQUIRED)
DB_HOST=db
DB_USERNAME=storehub
DB_PASSWORD=CHANGE_ME_use_strong_password

# Security (REQUIRED)
# Generate with: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_base64_encoded_256bit_secret
# Generate with: openssl rand -hex 32
AES_KEY=CHANGE_ME_64_hex_chars_for_aes256

# PostgreSQL (REQUIRED for Docker Compose)
POSTGRES_DB=storehub
POSTGRES_USER=storehub
POSTGRES_PASSWORD=CHANGE_ME_use_strong_password

# First-admin bootstrap (optional — remove after first login)
# If unset, bootstrap is skipped. Password must meet policy: 10+ chars, 1 number, 1 symbol.
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_min_10_chars_with_number_and_symbol
BOOTSTRAP_ADMIN_EMAIL=admin@storehub.local
