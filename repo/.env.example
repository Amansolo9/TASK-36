# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# Database
DB_HOST=db
DB_USERNAME=storehub
DB_PASSWORD=CHANGE_ME_use_strong_password

# Security - JWT secret must be Base64-encoded, minimum 256 bits
JWT_SECRET=CHANGE_ME_base64_encoded_256bit_secret

# Encryption - AES key must be 64 hex characters (256-bit)
AES_KEY=CHANGE_ME_64_hex_chars_for_aes256

# PostgreSQL (used by Docker Compose)
POSTGRES_DB=storehub
POSTGRES_USER=storehub
POSTGRES_PASSWORD=CHANGE_ME_use_strong_password

# First-admin bootstrap (remove after first login)
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_min_10_chars_with_number_and_symbol
BOOTSTRAP_ADMIN_EMAIL=admin@storehub.local
